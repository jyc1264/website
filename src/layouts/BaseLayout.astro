---
import { ClientRouter } from "astro:transitions";
import "@styles/global.css";
import "katex/dist/katex.min.css";
import { getPhotoAsset } from "../utils/photoAssets";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Machine Learning Engineer and Photographer portfolio.",
  ogImage = getPhotoAsset("DSCF2001.JPG").src,
} = Astro.props;

const siteName = "John Choi";
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://example.com").toString();
const normalizePath = (path: string) => path.replace(/\/+$/, "") || "/";
const currentPath = normalizePath(Astro.url.pathname);
const isActiveNavItem = (href: string) => {
  const navPath = normalizePath(href);

  if (navPath === "/") {
    return currentPath === "/";
  }

  return currentPath === navPath || currentPath.startsWith(`${navPath}/`);
};

const navItems = [
  { href: "/", label: "Home", active: isActiveNavItem("/") },
  { href: "/blog/", label: "Blog", active: isActiveNavItem("/blog/") },
  { href: "/gallery/", label: "Photography", active: isActiveNavItem("/gallery/") },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#725d4e" />
    <ClientRouter />
  </head>
  <body class="antialiased">
    <div class="mx-auto flex min-h-screen w-full max-w-[92rem] flex-col px-5 sm:px-8 lg:px-12">
      <header
        class="sticky top-0 z-30 -mx-5 border-b border-[#fff8ea]/20 bg-[#4e4037]/78 px-5 py-4 backdrop-blur sm:-mx-8 sm:px-8 lg:-mx-12 lg:px-12"
        transition:persist
      >
        <nav class="mx-auto flex max-w-content items-center justify-between gap-5" aria-label="Primary">
          <a href="/" class="font-mono text-sm text-[#fff8ea] transition hover:text-white">
            JC
          </a>
          <div class="primary-nav" data-primary-nav>
            <span class="primary-nav-indicator" data-primary-nav-indicator aria-hidden="true"></span>
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={["primary-nav-link", item.active && "is-active"]}
                data-primary-nav-link
                data-nav-path={item.href}
                aria-current={item.active ? "page" : undefined}
              >
                {item.label}
              </a>
            ))}
          </div>
        </nav>
      </header>

      <main class="mx-auto w-full max-w-content flex-1">
        <slot />
      </main>

      <footer class="mx-auto w-full max-w-content border-t border-[#fff8ea]/20 py-10">
        <div class="flex flex-col gap-4 text-sm text-[#e8d9c4] sm:flex-row sm:items-center sm:justify-between">
          <p class="font-mono">© {new Date().getFullYear()} {siteName}</p>
          <div class="flex flex-wrap gap-x-4 gap-y-2 font-mono">
            <a class="transition hover:text-white" href="mailto:jyc1261@outlook.com">Email</a>
            <a class="transition hover:text-white" href="https://www.linkedin.com/in/john-choi-24a83a149/" rel="noreferrer">LinkedIn</a>
          </div>
        </div>
      </footer>
    </div>
    <script is:inline>
      (() => {
        const NAV_SELECTOR = "[data-primary-nav]";
        const LINK_SELECTOR = "[data-primary-nav-link]";
        const INDICATOR_SELECTOR = "[data-primary-nav-indicator]";
        let primaryNavUpdateFrame = 0;

        const normalizePath = (path) => path.replace(/\/+$/, "") || "/";

        const linkMatchesPath = (link, pathname) => {
          const currentPath = normalizePath(pathname);
          const linkPath = normalizePath(link.dataset.navPath || new URL(link.href).pathname);

          if (linkPath === "/") {
            return currentPath === "/";
          }

          return currentPath === linkPath || currentPath.startsWith(`${linkPath}/`);
        };

        const updatePrimaryNav = () => {
          primaryNavUpdateFrame = 0;

          const nav = document.querySelector(NAV_SELECTOR);
          if (!(nav instanceof HTMLElement)) {
            return;
          }

          const indicator = nav.querySelector(INDICATOR_SELECTOR);
          const links = Array.from(nav.querySelectorAll(LINK_SELECTOR)).filter(
            (link) => link instanceof HTMLAnchorElement,
          );
          const activeLink = links.find((link) => linkMatchesPath(link, window.location.pathname)) || links[0];

          if (!(indicator instanceof HTMLElement) || !(activeLink instanceof HTMLAnchorElement)) {
            return;
          }

          for (const link of links) {
            const isActive = link === activeLink;

            link.classList.toggle("is-active", isActive);

            if (isActive) {
              link.setAttribute("aria-current", "page");
            } else {
              link.removeAttribute("aria-current");
            }
          }

          const navRect = nav.getBoundingClientRect();
          const activeRect = activeLink.getBoundingClientRect();
          const width = `${Math.round(activeRect.width * 100) / 100}px`;
          const transform = `translate3d(${Math.round((activeRect.left - navRect.left) * 100) / 100}px, 0, 0)`;

          if (indicator.style.width !== width) {
            indicator.style.width = width;
          }

          if (indicator.style.transform !== transform) {
            indicator.style.transform = transform;
          }

          indicator.style.opacity = "1";
          nav.classList.add("has-indicator");
        };

        const schedulePrimaryNavUpdate = () => {
          if (primaryNavUpdateFrame) {
            return;
          }

          primaryNavUpdateFrame = requestAnimationFrame(updatePrimaryNav);
        };

        if (!window.__primaryNavInitialized) {
          window.__primaryNavInitialized = true;
          document.addEventListener("astro:page-load", schedulePrimaryNavUpdate);
          window.addEventListener("resize", schedulePrimaryNavUpdate, { passive: true });
          window.addEventListener("orientationchange", schedulePrimaryNavUpdate, { passive: true });
        }

        schedulePrimaryNavUpdate();
      })();
    </script>
  </body>
</html>
