---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("tech");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"tech">;
}

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
}).format(post.data.pubDate);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="mx-auto max-w-3xl py-16 sm:py-20">
    <a
      class="inline-flex items-center gap-2 rounded-full border border-[#fff8ea]/20 bg-[#3b3029]/45 px-3 py-1.5 font-mono text-xs text-[#e8d9c4] transition hover:border-[#fff8ea]/45 hover:bg-[#fff8ea] hover:text-[#4e4037] focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-[#fff8ea]"
      href="/blog/"
      aria-label="Back to blog catalog"
    >
      <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M9.5 3.75 5.25 8l4.25 4.25" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M5.75 8h5.5" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" />
      </svg>
      Back to blog
    </a>
    <header class="mt-8 border-b border-[#fff8ea]/20 pb-10">
      <p class="meta-label font-mono text-xs text-[#d9c8ad]">Tech / ML · {formattedDate}</p>
      <h1 class="mt-5 text-5xl font-medium leading-tight text-[#fffaf0] sm:text-6xl">{post.data.title}</h1>
      <p class="mt-6 text-xl leading-8 text-[#e8d9c4]">{post.data.description}</p>
      <div class="mt-6 flex flex-wrap gap-2">
        {post.data.tags.map((tag) => (
          <span class="border border-[#fff8ea]/18 bg-[#3b3029]/60 px-2 py-1 font-mono text-[0.68rem] text-[#d9c8ad]">
            {tag}
          </span>
        ))}
      </div>
    </header>
    <div class="prose-portfolio mt-10">
      <Content />
    </div>
  </article>
</BaseLayout>
