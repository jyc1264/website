---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Card from "@components/Card.astro";

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(date);

const techPosts = (await getCollection("tech")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog" description="Technical blog posts by John Choi.">
  <section class="py-16 sm:py-20">
    <p class="meta-label font-mono text-xs text-[#d9c8ad]">Blog</p>
    <h1 class="mt-5 max-w-4xl text-5xl font-medium leading-tight text-[#fffaf0] sm:text-7xl">
      Research notes and build logs.
    </h1>
  </section>

  <section id="tech" class="section-rule scroll-mt-24 py-14">
    <div class="mb-8 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="meta-label font-mono text-xs text-[#d9c8ad]">Tech / ML</p>
        <h2 class="mt-3 text-4xl font-medium text-[#fffaf0]">Professional notes</h2>
      </div>
      <p class="font-mono text-xs text-[#d9c8ad]">{techPosts.length} entries</p>
    </div>
    <div class="grid gap-4">
      {techPosts.map((post) => (
        <Card
          href={`/blog/tech/${post.id}/`}
          eyebrow="Tech"
          title={post.data.title}
          description={post.data.description}
          meta={formatDate(post.data.pubDate)}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
