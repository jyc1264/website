---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Card from "@components/Card.astro";

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(date);

const techPosts = (await getCollection("tech")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog" description="Technical blog posts by John Choi.">
  <section class="py-16 sm:py-20">
    <div class="flex items-start justify-between gap-10">
      <div>
        <p class="meta-label font-mono text-xs text-[#d9c8ad]">Blog</p>
        <h1 class="mt-5 max-w-4xl text-5xl font-medium leading-tight text-[#fffaf0] sm:text-7xl">
          Research notes and what's been on my mind.
        </h1>
      </div>
      <svg
        class="mt-5 hidden h-40 w-40 shrink-0 text-[#d9c8ad]/70 lg:block xl:h-48 xl:w-48"
        viewBox="0 0 120 120"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M44 94c-9.5 0-17-7.2-17-16.2 0-3.8 1.4-7.5 3.8-10.3A16 16 0 0 1 34 36.1C36 25.9 45 18 56 18c6 0 11.6 2.4 15.7 6.7A20 20 0 0 1 96 44.2c0 2.4-.4 4.7-1.2 6.8A18.7 18.7 0 0 1 90 87.8c-3.1 0-6.1-.8-8.7-2.2A19 19 0 0 1 44 94Z"
          stroke="currentColor"
          stroke-width="2.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          d="M56 18v76M71.7 24.7c-4 3.6-6.2 8.4-6.2 13.5 0 5.9 3 11.3 8 14.6M55.8 38.2c-5.7 0-10.4-4-11.8-9.3M56 59.8c-6.8 0-12.5 4.4-14.5 10.4M56 76.5c5.5 0 10.4 2.7 13.2 6.9M82.7 52.9c-6.6 2.4-11 8.3-11 15.2 0 3.3 1 6.4 2.8 9M34 36.1c3.5-.2 6.9.8 9.8 2.7M30.8 67.5c3.1-2.8 7-4.3 11.2-4.3"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          opacity="0.86"
        />
      </svg>
    </div>
  </section>

  <section id="tech" class="scroll-mt-24 pb-14">
    <div class="grid gap-4">
      {techPosts.map((post) => (
        <Card
          href={`/blog/tech/${post.id}/`}
          eyebrow={post.data.category}
          title={post.data.title}
          description={post.data.description}
          meta={formatDate(post.data.pubDate)}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
