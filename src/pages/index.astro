---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Card from "@components/Card.astro";
import TimelineItem, { type CareerMilestone } from "@components/TimelineItem.astro";

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(date);

const milestones: CareerMilestone[] = [
  {
    period: "Apr 2025 - Present",
    company: "Reddit, Inc.",
    role: "Senior Machine Learning Engineer",
    description:
      "ML Infra work across ML Platform and ML Search Infrastructure.",
    focus: ["Vector DB Infrastructure", "Embedding Retrieval Optimization"],
  },
  {
    period: "Aug 2022 - Apr 2025",
    company: "Reddit, Inc.",
    role: "Software Engineer",
    description:
      "Built platform and product systems for Payments Platform and Anti-Fraud.",
    focus: ["Blockchain", "Kubernetes", "Vendor KYC"],
  },
  {
    period: "Aug 2021 - Aug 2022",
    company: "Niantic, Inc.",
    role: "Software Engineer",
    description:
      "Worked on Pokemon Go Infrastructure as a software engineer.",
    focus: ["GCS", "Unity Performance Tuning", "GeoSpatial Modeling"],
  },
];

const techPosts = (await getCollection("tech"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout title="John Choi" description="Machine Learning Engineer and Photographer portfolio.">
  <section class="grid min-h-[calc(100vh-4rem)] items-end gap-10 py-16 sm:py-20 lg:grid-cols-[1.2fr_0.8fr]">
    <div>
      <p class="meta-label font-mono text-xs text-[#d9c8ad]">Machine Learning Engineer & Photographer-Larper</p>
      <h1 class="mt-5 flex max-w-5xl flex-wrap items-baseline gap-x-5 gap-y-2 text-6xl font-medium leading-[0.95] tracking-normal text-[#fffaf0] sm:text-7xl lg:text-8xl">
        <span>John Choi</span>
        <span class="font-mono text-2xl font-normal leading-none text-[#e8d9c4] sm:text-3xl lg:text-4xl">최요한</span>
      </h1>
      <p class="mt-8 max-w-2xl text-xl leading-9 text-[#f1e4d0]">
        On my journey, developed real-world communities together at Niantic, and built/scaled semantic relevance at Reddit.
      </p>
    </div>
    <aside class="border-l border-[#fff8ea]/20 pl-6">
      <div class="grid gap-6">
        <div>
          <p class="meta-label font-mono text-[0.68rem] text-[#d9c8ad]">Focus</p>
          <p class="mt-2 text-2xl leading-tight text-[#fffaf0]">RAG Pipeline Optimization, Machine Learning Infrastructure, and Visual Storytelling.</p>
        </div>
        <div class="border-t border-[#fff8ea]/20 pt-6 font-mono text-xs text-[#d9c8ad]">
          <span>New York City</span>
        </div>
      </div>
    </aside>
  </section>

  <section class="section-rule grid gap-10 py-16 lg:grid-cols-[0.45fr_1fr]">
    <div>
      <p class="meta-label font-mono text-xs text-[#d9c8ad]">Experience</p>
      <h2 class="mt-4 text-4xl font-medium leading-tight text-[#fffaf0]">Where I worked, what I built, and when.</h2>
    </div>
    <ol>
      {milestones.map((item, index) => (
        <TimelineItem item={item} last={index === milestones.length - 1} />
      ))}
    </ol>
  </section>

  <section class="section-rule py-16">
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="meta-label font-mono text-xs text-[#d9c8ad]">Recent Writing</p>
        <h2 class="mt-4 text-4xl font-medium text-[#fffaf0]">Technical notes</h2>
      </div>
      <a class="font-mono text-sm text-[#e8d9c4] underline transition hover:text-white" href="/blog/">All writing</a>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {techPosts.map((post) => (
        <Card
          href={`/blog/tech/${post.id}/`}
          eyebrow="Tech / ML"
          title={post.data.title}
          description={post.data.description}
          meta={formatDate(post.data.pubDate)}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
