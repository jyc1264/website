---
import BaseLayout from "@layouts/BaseLayout.astro";
import TimelineItem, { type CareerMilestone } from "@components/TimelineItem.astro";

const milestones: CareerMilestone[] = [
  {
    period: "Apr 2025 - Present",
    company: "Reddit, Inc.",
    role: "Senior Machine Learning Engineer",
    description: [
      "Delivered Milvus-backed semantic retrieval on Reddit Feeds, improving new-user activation and retention (~1M+ DAU) while meeting strict latency and availability SLOs.",
      "Launched SEO search experiences in collaboration with 3 teams, driving an increase of ~500k DAU.",
      "Reduced ML server costs ~$1.5M/year with a distributed caching solution and improved search resilience with adaptive traffic shedding across high-QPS endpoints.",
      "Developed an automated resource cleanup controller for vector database lifecycle management saving ~$360k/year.",
    ],
    focus: ["Vector DB Infrastructure", "Embedding Retrieval Optimization"],
  },
  {
    period: "Aug 2022 - Apr 2025",
    company: "Reddit, Inc.",
    role: "Software Engineer III",
    description: [
      "Led creator payouts and reconciliation, distributing multi-million-dollar payouts across 30+ countries and 25+ currencies.",
      "Built payment webhook and verification services for Apple, Google, and Stripe notifications across purchase, refund, fraud, and reconciliation flows.",
      "Built automated E2E testing suite across Payments critical paths, catching release-blocking regressions before production launch.",
    ],
    focus: ["Blockchain", "Kubernetes", "Vendor KYC"],
  },
  {
    period: "Aug 2021 - Aug 2022",
    company: "Niantic, Inc.",
    role: "Software Engineer",
    description: [
      "Rebuilt Pokemon Go quest and rewards flows, reducing high-traffic quest page load time by 25%.",
      "Shipped guest-account onboarding that improved post-launch player retention by 30%.",
      "Partnered with AR/R&D teams on Pokestop 3D scan uploads to support AR mapping platform development.",
    ],
    focus: ["GCS", "Unity Performance Tuning", "GeoSpatial Modeling"],
  },
];
---

<BaseLayout title="John Choi" description="Machine Learning Engineer and Photographer portfolio.">
  <section class="relative grid min-h-[calc(100vh-4rem)] items-end gap-10 py-16 sm:py-20 lg:grid-cols-[1.2fr_0.8fr]">
    <div>
      <p class="meta-label font-mono text-xs text-[#d9c8ad]">Machine Learning Engineer & Photographer-Larper</p>
      <h1 class="mt-5 flex max-w-5xl flex-wrap items-baseline gap-x-5 gap-y-2 text-6xl font-medium leading-[0.95] tracking-normal text-[#fffaf0] sm:text-7xl lg:text-8xl">
        <span>John Choi</span>
        <span class="text-2xl font-normal leading-none text-[#e8d9c4] sm:text-3xl lg:text-4xl">최요한</span>
      </h1>
      <p class="mt-8 max-w-2xl text-xl leading-9 text-[#f1e4d0]">
        On my journey, developed real-world communities together at Niantic and scaled semantic relevance at Reddit.
      </p>
    </div>
    <aside class="border-l border-[#fff8ea]/20 pl-6">
      <div class="grid gap-6">
        <div>
          <p class="meta-label font-mono text-[0.68rem] text-[#d9c8ad]">Focus</p>
          <p class="mt-2 text-2xl leading-tight text-[#fffaf0]">RAG Pipeline Optimization, Machine Learning Infrastructure, and Visual Storytelling.</p>
        </div>
        <div class="border-t border-[#fff8ea]/20 pt-6 font-mono text-xs text-[#d9c8ad]">
          <span>New York City</span>
        </div>
      </div>
    </aside>
    <a
      href="#experience"
      data-scroll-cue
      class="absolute bottom-6 left-1/2 inline-flex -translate-x-1/2 items-center justify-center px-4 py-3 text-[#fff8ea]/70 transition duration-500 hover:text-[#fff8ea] focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-4 focus-visible:outline-[#fff8ea]"
    >
      <span class="sr-only">Scroll to experience</span>
      <svg class="h-10 w-10 animate-bounce drop-shadow-[0_0_18px_rgba(255,248,234,0.18)]" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <path d="M9 11.5 16 18l7-6.5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M9 18 16 24.5 23 18" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round" opacity="0.62"></path>
      </svg>
    </a>
  </section>

  <section id="experience" class="section-rule grid scroll-mt-24 gap-10 py-16 lg:grid-cols-[0.45fr_1fr]">
    <div>
      <p class="meta-label font-mono text-xs text-[#d9c8ad]">Experience</p>
      <h2 class="mt-4 text-4xl font-medium leading-tight text-[#fffaf0]">Where I worked, what I built, and when.</h2>
    </div>
    <ol>
      {milestones.map((item, index) => (
        <TimelineItem item={item} last={index === milestones.length - 1} />
      ))}
    </ol>
  </section>

  <script is:inline>
    (() => {
      const CUE_SELECTOR = "[data-scroll-cue]";
      const HIDDEN_CLASS = "scroll-cue-hidden";

      const hideCue = () => {
        const cue = document.querySelector(CUE_SELECTOR);

        if (cue instanceof HTMLElement) {
          cue.classList.add(HIDDEN_CLASS);
        }
      };

      const syncCue = () => {
        if (window.scrollY > 8) {
          hideCue();
        }
      };

      if (!window.__scrollCueInitialized) {
        window.__scrollCueInitialized = true;

        ["scroll", "wheel", "touchstart"].forEach((eventName) => {
          window.addEventListener(eventName, hideCue, { passive: true, capture: true });
        });

        ["pointerdown", "keydown", "focusin"].forEach((eventName) => {
          window.addEventListener(eventName, hideCue, { capture: true });
        });

        document.addEventListener("astro:page-load", syncCue);
      }

      syncCue();
    })();
  </script>
</BaseLayout>
