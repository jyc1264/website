---
export interface Props {
  title: string;
  description: string;
  href?: string;
  eyebrow?: string;
  meta?: string;
  tags?: string[];
}

const { title, description, href, eyebrow, meta, tags = [] } = Astro.props;

const classes =
  "group block border border-[#fff8ea]/20 bg-[#3b3029]/62 p-5 backdrop-blur-sm transition hover:border-[#fff8ea]/45 hover:bg-[#4e4037]/72";
---

{
  href ? (
    <a href={href} class={classes}>
      <div class="flex flex-col gap-4">
        <div class="flex flex-wrap items-center justify-between gap-3 font-mono text-[0.7rem] text-[#d9c8ad]">
          {eyebrow && <span class="meta-label">{eyebrow}</span>}
          {meta && <time>{meta}</time>}
        </div>
        <div>
          <h3 class="text-xl font-medium leading-tight text-[#fffaf0] transition group-hover:text-white">{title}</h3>
          <p class="mt-3 text-sm leading-6 text-[#e8d9c4]">{description}</p>
        </div>
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="border border-[#fff8ea]/18 px-2 py-1 font-mono text-[0.68rem] text-[#d9c8ad]">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </a>
  ) : (
    <article class={classes}>
      <div class="flex flex-col gap-4">
        <div class="flex flex-wrap items-center justify-between gap-3 font-mono text-[0.7rem] text-[#d9c8ad]">
          {eyebrow && <span class="meta-label">{eyebrow}</span>}
          {meta && <time>{meta}</time>}
        </div>
        <div>
          <h3 class="text-xl font-medium leading-tight text-[#fffaf0]">{title}</h3>
          <p class="mt-3 text-sm leading-6 text-[#e8d9c4]">{description}</p>
        </div>
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="border border-[#fff8ea]/18 px-2 py-1 font-mono text-[0.68rem] text-[#d9c8ad]">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </article>
  )
}
