---
export interface CareerMilestone {
  period: string;
  company: string;
  role: string;
  description: string | string[];
  focus?: string[];
}

export interface Props {
  item: CareerMilestone;
  last?: boolean;
}

const { item, last = false } = Astro.props;
---

<li class="grid gap-5 sm:grid-cols-[9rem_1fr]">
  <div class="font-mono text-xs text-[#d9c8ad] sm:pt-1">
    <span class="meta-label">{item.period}</span>
  </div>
  <div class="relative pb-10 sm:pb-12">
    {!last && <div class="absolute left-[0.31rem] top-3 h-full w-px bg-[#fff8ea]/20" aria-hidden="true"></div>}
    <div class="relative pl-8">
      <span class="absolute left-0 top-1.5 h-3 w-3 rounded-full border border-[#fff8ea]/55 bg-[#4e4037]" aria-hidden="true"></span>
      <p class="meta-label font-mono text-[0.68rem] text-[#d9c8ad]">{item.company}</p>
      <h3 class="mt-2 text-2xl font-medium leading-tight text-[#fffaf0]">{item.role}</h3>
      {Array.isArray(item.description) ? (
        <ul class="mt-3 max-w-3xl list-disc space-y-2 pl-5 text-base leading-7 text-[#e8d9c4]">
          {item.description.map((description) => (
            <li>{description}</li>
          ))}
        </ul>
      ) : (
        <p class="mt-3 max-w-3xl text-base leading-7 text-[#e8d9c4]">{item.description}</p>
      )}
      {item.focus && item.focus.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {item.focus.map((tag) => (
            <span class="border border-[#fff8ea]/18 bg-[#3b3029]/60 px-2 py-1 font-mono text-[0.68rem] text-[#d9c8ad]">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</li>
